<%
  var introSource = (page.excerpt || page.content || '')
    .replace(/<pre[\s\S]*?<\/pre>/gi, ' ')
    .replace(/<figure[\s\S]*?<\/figure>/gi, ' ')
    .replace(/<blockquote[\s\S]*?<\/blockquote>/gi, ' ');
  var plainContent = strip_html(introSource)
    .replace(/!\[[^\]]*\]\([^)]+\)/g, ' ')
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '$1 ')
    .replace(/`{1,3}[^`]*`{1,3}/g, ' ')
    .replace(/[^\S\r\n]+/g, ' ')
    .replace(/https?:\/\/\S+/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
  var introCommandLikeCount = (plainContent.match(/\b(sudo|npm|pnpm|yarn|brew|git|pmset|hexo)\b/gi) || []).length;
  var introCjkCount = (plainContent.match(/[\u4e00-\u9fff]/g) || []).length;
  var intro = plainContent.length >= 24 && !(introCommandLikeCount >= 2 && introCjkCount < 18)
    ? truncate(plainContent, { length: 140 })
    : '';
%>
<article class="ac-post-shell">
  <header class="ac-post-header">
    <p class="ac-eyebrow">Blog post</p>
    <h1><%= page.title %></h1>
    <div class="ac-post-meta">
      <time datetime="<%= full_date(page.date, 'YYYY-MM-DD HH:mm:ss') %>"><%= date(page.date, 'YYYY-MM-DD') %></time>
      <% if (page.tags && page.tags.length) { %>
        <div class="ac-tag-row">
          <% page.tags.each(function(tag){ %>
            <a class="ac-tag-chip" href="<%- url_for(tag.path) %>"><%= tag.name %></a>
          <% }) %>
        </div>
      <% } %>
    </div>
    <% if (intro) { %>
      <p class="ac-post-intro"><%= intro %></p>
    <% } %>
  </header>

  <div class="ac-divider"></div>

  <div class="ac-prose">
    <%- page.content %>
  </div>

  <div class="ac-post-nav">
    <% if (page.prev) { %>
      <a class="ac-nav-card" href="<%- url_for(page.prev.path) %>">
        <span>上一篇</span>
        <strong><%= page.prev.title %></strong>
      </a>
    <% } else { %>
      <div class="ac-nav-card ac-nav-card-empty">
        <span>上一篇</span>
        <strong>已经是第一篇了</strong>
      </div>
    <% } %>

    <% if (page.next) { %>
      <a class="ac-nav-card" href="<%- url_for(page.next.path) %>">
        <span>下一篇</span>
        <strong><%= page.next.title %></strong>
      </a>
    <% } else { %>
      <div class="ac-nav-card ac-nav-card-empty">
        <span>下一篇</span>
        <strong>已经是最后一篇了</strong>
      </div>
    <% } %>
  </div>
</article>
