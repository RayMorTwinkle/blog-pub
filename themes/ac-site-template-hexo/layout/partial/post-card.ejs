<%
  var contentSource = (post.excerpt || post.content || '')
    .replace(/<pre[\s\S]*?<\/pre>/gi, ' ')
    .replace(/<figure[\s\S]*?<\/figure>/gi, ' ')
    .replace(/<blockquote[\s\S]*?<\/blockquote>/gi, ' ');
  var rawContent = strip_html(contentSource)
    .replace(/!\[[^\]]*\]\([^)]+\)/g, ' ')
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '$1 ')
    .replace(/`{1,3}[^`]*`{1,3}/g, ' ')
    .replace(/(^|\s)[>#*_~-]+/g, ' ')
    .replace(/[^\S\r\n]+/g, ' ')
    .replace(/https?:\/\/\S+/g, ' ')
    .replace(/&[a-z0-9#]+;/gi, ' ')
    .replace(/\s+/g, ' ')
    .trim();
  var commandLikeCount = (rawContent.match(/\b(sudo|npm|pnpm|yarn|brew|git|pmset|hexo)\b/gi) || []).length;
  var cjkCount = (rawContent.match(/[\u4e00-\u9fff]/g) || []).length;
  var summary = rawContent.length >= 18 && !(commandLikeCount >= 2 && cjkCount < 14)
    ? truncate(rawContent, { length: 110 })
    : '';
%>
<article class="ac-post-card">
  <div class="ac-post-card-head">
    <time datetime="<%= full_date(post.date, 'YYYY-MM-DD HH:mm:ss') %>"><%= date(post.date, 'YYYY-MM-DD') %></time>
    <% if (post.tags && post.tags.length) { %>
      <div class="ac-post-card-tags">
        <% post.tags.each(function(tag){ %>
          <a href="<%- url_for(tag.path) %>"><%= tag.name %></a>
        <% }) %>
      </div>
    <% } %>
  </div>
  <h3><a href="<%- url_for(post.path) %>"><%= post.title %></a></h3>
  <p><%= summary || '打开这篇文章，继续查看完整内容、步骤和配图。' %></p>
  <a class="ac-card-link" href="<%- url_for(post.path) %>">继续阅读</a>
</article>
